{
  "name": "css-paint-worklet-kit",
  "version": "0.2.0",
  "description": "CSS Houdini Paint Worklets with React hook API — noise, confetti, gradient, glitch, liquid-blob. Off-main-thread canvas effects, SSR safe, TypeScript.",
  "type": "module",
  "main": "./dist/index.cjs.js",
  "module": "./dist/index.esm.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "dev": "vite --config demo/vite.config.ts",
    "build": "vite build && tsc --emitDeclarationOnly --declaration --outDir dist",
    "build:demo": "vite build --config demo/vite.config.ts",
    "preview": "vite preview --config demo/vite.config.ts",
    "type-check": "tsc --noEmit",
    "lint": "eslint src demo/src --ext .ts,.tsx",
    "test": "vitest run"
  },
  "keywords": [
    "css",
    "houdini",
    "paint",
    "worklet",
    "react",
    "hook",
    "noise",
    "glitch",
    "confetti",
    "gradient",
    "liquid-blob",
    "metaball",
    "canvas",
    "css-paint-api",
    "animation",
    "off-main-thread"
  ],
  "author": {
    "name": "Dominik Pawlikowski",
    "url": "https://github.com/dpawlikowski"
  },
  "homepage": "https://dpawlikowski.github.io/css-paint-worklet-kit/",
  "repository": {
    "type": "git",
    "url": "https://github.com/dpawlikowski/css-paint-worklet-kit.git"
  },
  "bugs": {
    "url": "https://github.com/dpawlikowski/css-paint-worklet-kit/issues"
  },
  "license": "MIT",
  "peerDependencies": {
    "react": ">=17"
  },
  "dependencies": {
    "css-paint-polyfill": "^3.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "@vitejs/plugin-react": "^4.3.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.1.1",
    "prettier": "^3.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.5.0",
    "vite": "^5.3.0",
    "vite-plugin-dts": "^3.9.0",
    "vitest": "^1.6.0"
  }
}
